---
# find and count unique subjects
---
{%- assign items = site.data.posters -%}
{%- assign subjects = "" -%}
{%- for item in items -%}
  {%- if item.subject -%}
    {%- assign subjects = subjects | append: ";" | append: item.subject -%}
  {%- endif -%}
{%- endfor -%}
{%- assign uniqSubjects = subjects | split: ";" | compact | uniq | sort -%}
{ 
  "subjects": [
    {% for s in uniqSubjects %}{% if s != "" %}{ 
      "subject" : {{ s | strip | jsonify }}, 
      "link" : {{ s | strip | url_param_escape | prepend: '/browse.html#' | absolute_url | jsonify }} 
    }{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}
  ]
}
