---
# find and count unique subjects
layout: null
---
{%- assign items = site.data.posters -%}
{%- assign subjects_string = "" -%}

{%- for item in items -%}
  {%- if item.subject and item.subject != "" -%}
    {%- assign subjects_string = subjects_string | append: ";" | append: item.subject -%}
  {%- endif -%}
{%- endfor -%}

{%- assign raw_subjects = subjects_string | split: ";" | compact | uniq | sort -%}
{%- assign final_subjects = "" | split: "," -%}

{%- for s in raw_subjects -%}
  {%- assign cleaned = s | strip -%}
  {%- if cleaned != "" -%}
    {%- capture subject_obj -%}
      {
        "subject": {{ cleaned | jsonify }},
        "link": {{ cleaned | url_param_escape | prepend: '/browse.html#' | absolute_url | jsonify }}
      }
    {%- endcapture -%}
    {%- assign final_subjects = final_subjects | push: subject_obj -%}
  {%- endif -%}
{%- endfor -%}

{
  "subjects": [
    {{ final_subjects | join: "," }}
  ]
}
